# Auto-detect text files and normalize line endings
* text=auto

# Force LF for Unix-based files
*.java text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.sh text eol=lf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf

# Maven wrapper
/mvnw text eol=lf
/mvnw.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.jar binary
*.war binary